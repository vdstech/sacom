NODE_ENV=production
HOST=127.0.0.1
ENABLE_TLS=false
PORT=4445
HTTPS_PORT=4445
HTTP_PORT=4045
REDIRECT_SERVER=false
MONGO_URI=mongodb+srv://demo_user:replace_me@cluster.example.mongodb.net/commerce_db?retryWrites=true&w=majority
ACCESS_TOKEN_SECRET=replace_with_the_same_auth_secret
CUSTOMER_ACCESS_TOKEN_SECRET=
TRUST_PROXY=true
CORS_ORIGINS=https://store.example.com,https://admin.example.com
CATALOG_SVC_URL=http://127.0.0.1:4444
DEFAULT_PRODUCT_TAX_RATE=0.05
CATEGORY_FILTER_CONFIG_CACHE_MS=30000
STRICT_VARIANT_FACET_VALIDATION=
REVIEW_MODERATION_PROVIDER=openai
OPENAI_API_KEY=
REVIEW_MODERATION_MODEL=omni-moderation-latest
REVIEW_MODERATION_TIMEOUT_MS=5000
REVIEW_MODERATION_MAX_REVIEWS_PER_WINDOW=5
REVIEW_MODERATION_RATE_WINDOW_MS=600000
