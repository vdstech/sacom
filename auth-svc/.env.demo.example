NODE_ENV=production
HOST=127.0.0.1
ENABLE_TLS=false
PORT=4443
HTTPS_PORT=4443
HTTP_PORT=4040
REDIRECT_SERVER=false
MONGO_URI=mongodb+srv://demo_user:replace_me@cluster.example.mongodb.net/commerce_db?retryWrites=true&w=majority
ACCESS_TOKEN_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_TTL=7d
CUSTOMER_ACCESS_TOKEN_SECRET=
CUSTOMER_ACCESS_TOKEN_TTL=15m
TRUST_PROXY=true
CORS_ORIGINS=https://store.example.com,https://admin.example.com
BOOTSTRAP_ADMIN_SECRET=replace_with_a_long_random_secret
PASSWORD_MIN_LENGTH=12
PASSWORD_MIN_LOWER_CASE=1
PASSWORD_MIN_UPPER_CASE=1
PASSWORD_MIN_NUMBERS=1
PASSWORD_MIN_SYMBOLS=1
DEFAULT_PRODUCT_TAX_RATE=0.05
STANDARD_SHIPPING_CHARGE=50
FREE_SHIPPING_CART_VALUE=999
PRICING_RULE_VERSION=2
ORDER_TARGET_COMPLETION_HOURS=72
AUDIT_LOG_RETENTION_DAYS=
AUDIT_LOG_CLEANUP_INTERVAL_MS=86400000
SUPER_ADMIN_EMAIL=demo-admin@example.com
SUPER_ADMIN_PASSWORD=replace_with_a_unique_demo_password
