ENABLE_TLS=false
HTTPS_PORT=4443
HTTP_PORT=4040
REDIRECT_SERVER=true
TLS_CERT_PATH=./certs/localhost.crt
TLS_KEY_PATH=./certs/localhost.key
MONGO_URI=mongodb://localhost:27017/commerce_db
TRUST_PROXY=true

BOOTSTRAP_ADMIN_SECRET=change_me
PASSWORD_MIN_LENGTH=12
PASSWORD_MIN_LOWER_CASE=1
PASSWORD_MIN_UPPER_CASE=1
PASSWORD_MIN_NUMBERS=1
PASSWORD_MIN_SYMBOLS=1

ACCESS_TOKEN_SECRET=change_me
ACCESS_TOKEN_TTL=7d
DEFAULT_PRODUCT_TAX_RATE=0.05
STANDARD_SHIPPING_CHARGE=50
FREE_SHIPPING_CART_VALUE=999
PRICING_RULE_VERSION=2
# Leave blank to retain audit logs indefinitely in v1.
AUDIT_LOG_RETENTION_DAYS=
AUDIT_LOG_CLEANUP_INTERVAL_MS=86400000

# Set these before running `npm run seed`.
SUPER_ADMIN_EMAIL=superadmin@sa.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
